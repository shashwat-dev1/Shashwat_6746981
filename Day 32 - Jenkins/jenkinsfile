pipeline {
agent any

```
tools {
    nodejs 'NodeJS'
}

options {
    timestamps()
}

environment {
    PROJECT_DIR = "Day 32 - Jenkins"
}

stages {

    stage('Checkout Code') {
        steps {
            checkout scm
        }
    }

    stage('Verify Structure') {
        steps {
            dir("${PROJECT_DIR}") {
                bat 'dir'
            }
        }
    }

    stage('Install Dependencies') {
        steps {
            dir("${PROJECT_DIR}") {
                bat 'npm install'
                bat 'npx playwright install'
            }
        }
    }

    stage('Run Playwright Tests') {
        steps {
            dir("${PROJECT_DIR}") {
                script {
                    def status = bat(script: 'npx playwright test', returnStatus: true)

                    if (status != 0) {
                        echo "Test execution failed, marking build UNSTABLE but continuing..."
                        currentBuild.result = 'UNSTABLE'
                    }
                }
            }
        }
    }
}

post {

    always {
        echo 'Publishing Playwright HTML Report...'

        dir("${PROJECT_DIR}") {

            publishHTML(target: [
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: 'Playwright Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])

            archiveArtifacts artifacts: 'playwright-report/**/*', allowEmptyArchive: true
        }
    }

    success {
        echo 'Build SUCCESS: All stages executed correctly.'
    }

    unstable {
        echo 'Build UNSTABLE: Tests failed but pipeline continued.'
    }

    failure {
        echo 'Build FAILURE: Critical issue occurred.'
    }
}
```

}
