pipeline {
agent any

```
tools {
    nodejs 'NodeJS'
}

options {
    timestamps()
}

environment {
    PROJECT_DIR = "Day 32 - Jenkins"
}

stages {

    stage('Checkout Code') {
        steps {
            checkout scm
        }
    }

    stage('Install Dependencies') {
        steps {
            dir("${PROJECT_DIR}") {
                bat "npm install"
                bat "npx playwright install"
            }
        }
    }

    stage('Run Tests') {
        steps {
            dir("${PROJECT_DIR}") {
                script {
                    def status = bat(script: "npx playwright test", returnStatus: true)
                    if (status != 0) {
                        echo "Tests failed, marking build UNSTABLE"
                        currentBuild.result = 'UNSTABLE'
                    }
                }
            }
        }
    }
}

post {
    always {
        dir("${PROJECT_DIR}") {
            publishHTML(target: [
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: 'Playwright Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])

            archiveArtifacts artifacts: 'playwright-report/**/*', allowEmptyArchive: true
        }
    }
}
```

}
