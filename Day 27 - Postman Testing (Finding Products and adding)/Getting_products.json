{
  "info": {
    "_postman_id": "b35fc9ec-0baa-4976-ad7f-56a34373e5e1",
    "name": "ShopperStack",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "53447975"
  },
  "item": [
    {
      "name": "Login",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response=JSON.parse(responseBody)\r",
                  "pm.globals.set(\"token\",response.data.jwtToken)\r",
                  "pm.globals.set(\"shopperId\",response.data.userId)"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"testinguser12@gmail.com\",\r\n  \"password\": \"12345678\",\r\n  \"role\": \"SHOPPER\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{BaseURL}}/users/login",
              "host": [
                "{{BaseURL}}"
              ],
              "path": [
                "users",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Product",
      "item": [
        {
          "name": "Getting Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = JSON.parse(responseBody)\r",
                  "pm.globals.set(\"product1\",response.data[0].productId)\r",
                  "pm.globals.set(\"product2\",response.data[2].productId)"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BaseURL}}/products/alpha",
              "host": [
                "{{BaseURL}}"
              ],
              "path": [
                "products",
                "alpha"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Adding to Cart",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"productId\": {{product1}},\r\n  \"quantity\": 5\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{BaseURL}}/shoppers/{{shopperId}}/carts",
              "host": [
                "{{BaseURL}}"
              ],
              "path": [
                "shoppers",
                "{{shopperId}}",
                "carts"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}